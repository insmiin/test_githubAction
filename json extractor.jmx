        <kg.apc.jmeter.samplers.DummySampler guiclass="kg.apc.jmeter.samplers.DummySamplerGui" testclass="kg.apc.jmeter.samplers.DummySampler" testname="jp@gc - Dummy Sampler6" enabled="true">
          <boolProp name="WAITING">true</boolProp>
          <boolProp name="SUCCESFULL">true</boolProp>
          <stringProp name="RESPONSE_CODE">200</stringProp>
          <stringProp name="RESPONSE_MESSAGE">OK</stringProp>
          <stringProp name="REQUEST_DATA">https://www.blazemeter.com/blog/json-extractor
https://docs.hevodata.com/sources/engg-analytics/streaming/rest-api/writing-jsonpath-expressions/

dot represent dict/{}
[] represent list</stringProp>
          <stringProp name="RESPONSE_DATA">{
  &quot;day&quot;:&quot;sunday&quot;,                           
  &quot;event&quot;: {                                     
    &quot;name&quot;: &quot;Bond Movies&quot;,
    &quot;cinema&quot;:{
      &quot;new&quot;:&quot;yes&quot;,
      &quot;old&quot;:&quot;no&quot;
     },
    &quot;movies&quot;: [
      {
        &quot;name&quot;: &quot;Licence to Kill&quot;,
        &quot;star&quot;: &quot;Timothy Dalton&quot;,
        &quot;rating&quot;: 6.6
      },
      {
        &quot;name&quot;: &quot;GoldenEye&quot;,
        &quot;star&quot;: &quot;Pierce Brosnan&quot;,
        &quot;rating&quot;: 7.2
      },
      {
        &quot;name&quot;: &quot;Tomorrow Never Dies&quot;,
        &quot;star&quot;: &quot;Pierce Brosnan&quot;,
        &quot;rating&quot;: 6.5
      },
      {
        &quot;name&quot;: &quot;Tomorrow Never Dies&quot;,
        &quot;star&quot;: &quot;Pierce Brosnan&quot;,
        &quot;rating&quot;: 6.5,
        &quot;IMDB&quot;:&quot;yes&quot;
      }
    ]
  },
  &quot;date&quot;:{
     &quot;year&quot;:2022,
     &quot;mon&quot;:&quot;feb&quot;
  }
}</stringProp>
          <stringProp name="RESPONSE_TIME">${__Random(50,500)}</stringProp>
          <stringProp name="LATENCY">${__Random(1,50)}</stringProp>
          <stringProp name="CONNECT">${__Random(1,5)}</stringProp>
          <stringProp name="URL"></stringProp>
          <stringProp name="RESULT_CLASS">org.apache.jmeter.samplers.SampleResult</stringProp>
          <stringProp name="TestPlan.comments">how json extractor works</stringProp>
