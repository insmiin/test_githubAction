        <hashTree>
          <JSR223Timer guiclass="TestBeanGUI" testclass="JSR223Timer" testname="NOTES" enabled="false">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">//  $ is root, dot is like dictionary{} level, object behind dot is the element on that level since one level can have many elements
//  sample below:  
	//day,event &amp; date is on first level   eg.  $.event  (mz specify object behind to know which element to use, day or event or year)
	//name,add,movie is on second level after event    eg.$.event.cinema
	//year &amp; mon is also on second level after date   eg. $.date.year
//               
{
  &quot;day&quot;:&quot;sunday&quot;,                          //$.day
  &quot;event&quot;: {                            //$.event 
    &quot;name&quot;: &quot;Bond Movies&quot;,       //$.event.name  or $..name(but bcare cuz there is also name under movies element)
    &quot;add&quot;:{                   //$.event.add
      &quot;unit&quot;:&quot;123&quot;,               //$.event.add.unit
      &quot;road&quot;:&quot;jalanABC&quot;			
    },
    &quot;movies&quot;: [		//$.event.movies
      {				//$.event.movies[0]
        &quot;name&quot;: &quot;Licence to Kill&quot;,		//to get 1st name $.event.movies[0].name  //to get name of all movies use $.event.movies[0:].name
        &quot;star&quot;: &quot;Timothy Dalton&quot;,
        &quot;rating&quot;: 6.6
      },
      {				//$.event.movies[1]
        &quot;name&quot;: &quot;GoldenEye&quot;,			//$.event.movies[1].name
        &quot;star&quot;: &quot;Pierce Brosnan&quot;,
        &quot;rating&quot;: 7.2
      },
      {
        &quot;name&quot;: &quot;Tomorrow Never Dies&quot;,
        &quot;star&quot;: &quot;Pierce Brosnan&quot;,
        &quot;rating&quot;: 6.5
      },
      {
        &quot;name&quot;: &quot;Tomorrow Never Dies&quot;,
        &quot;star&quot;: &quot;Pierce Brosnan&quot;,
        &quot;rating&quot;: 6.5,
        &quot;IMDB&quot;:&quot;yes&quot;
      }
    ]
  },
  &quot;date&quot;:{
    &quot;year&quot;:2022,
    &quot;mon&quot;:&quot;feb&quot;
  }
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Timer>
          <hashTree/>
          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="JSON Extractor" enabled="true">
            <stringProp name="JSONPostProcessor.referenceNames">MvRate&gt;6deName</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.event.movies[?(@.rating &gt; 6.6)].name</stringProp>
            <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
            <boolProp name="JSONPostProcessor.compute_concat">true</boolProp>
            <stringProp name="JSONPostProcessor.defaultValues">0</stringProp>
          </JSONPostProcessor>
          <hashTree/>
          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="JSON Extractor" enabled="true">
            <stringProp name="JSONPostProcessor.referenceNames">_1stMvName; year;  MvRate&gt;6;    MvUseIMDBratig</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.event.movies[0].name;  $.date.year;  $.event.movies[?(@.rating &gt; 6.6)];  $.event.movies[?(@.rating == 6.5 &amp;&amp; @.IMDB)] </stringProp>
            <stringProp name="JSONPostProcessor.match_numbers">-1 ;-1;-1;-1</stringProp>
            <boolProp name="JSONPostProcessor.compute_concat">true</boolProp>
            <stringProp name="JSONPostProcessor.defaultValues">0;0;0;0</stringProp>
          </JSONPostProcessor>
          <hashTree/>
        </hashTree>
