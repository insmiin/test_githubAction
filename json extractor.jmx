          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">/*
String jmeter_param = &quot;book_property_&quot; + &quot;1&quot;
log.info(&apos;jmeter_param: =======&apos; + jmeter_param)
def book_dict = vars.get(jmeter_param)    // to get variable value // !!!!! enclosed with &quot; &quot; if it is jmeter variable. no need &quot; &quot; if it is variable defined here !!!
log.info(&apos;book_dict: =======&apos; + book_dict)   
log.info(&apos;book_dict type :======&apos; + book_dict.getClass() )  //to get type of variable
*/
      
/*
==================ALL DONE. PROCEED TO NEXT STEP - GETBETINFO AND PLACEBET!!!!!!!!!!!!!!==============
def body = prev.getResponseDataAsString();  //learn how to process json response 
log.info(&apos;body====&apos; + body.getClass())
*/
import groovy.json.JsonSlurper

int MatchNbr = Integer.parseInt(vars.get(&quot;WagerSelection_matchNr&quot;).trim());  //convert string into int and trim the leading/trailing space
log.info(&quot;MatchNbr====&quot;+MatchNbr)
for ( i in 1..MatchNbr ) {
    log.info(&quot;MatchNbr start====&quot;+i+ &quot;====loop&quot;);
    String jmeter_param = &quot;WagerSelection_&quot; + i;
    log.info(&apos;jmeter_param: =======&apos; + jmeter_param)
  
    def jsonSlurper = new JsonSlurper()
    def wagsel_list = vars.get(jmeter_param)
    result = jsonSlurper.parseText(wagsel_list)
    log.info(&apos;result====&apos; + result)     // [name:Foo Bar, year:2018, timestamp:2018-03-08T00:00:00, tags:[person, employee], grade:3.14]
    //log.info(&apos;BetTypeIDa====&apos;+result[&apos;BetTypeID&apos;])  // Foo Bar
    //log.info(&apos;BetTypeIDb====&apos; + result.BetTypeID)     // Foo Bar
	String selection = &quot;&quot;
    if (result.BetTypeID == 1 &amp; result.BetTypeSelectionId == 1 &amp; result.PeriodId ==1){ //same event can only have 1 markettype :either live today or early  //case sensitive result.abc != result.Abc
    	selection = &quot;H_FT&quot;
    }
    else if(result.BetTypeID == 1 &amp; result.BetTypeSelectionId == 2 &amp; result.PeriodId ==1){
    	selection = &quot;A_FT&quot;
    }
    else if(result.BetTypeID == 2 &amp; result.BetTypeSelectionId == 3 &amp; result.PeriodId ==1){
    	selection = &quot;Ov_FT&quot;
    }
    else if(result.BetTypeID == 2 &amp; result.BetTypeSelectionId == 4 &amp; result.PeriodId ==1){
    	selection = &quot;U_FT&quot;
    }
    else{
    	vars.put(&quot;Unknown_Hdp&quot;,String.valueOf(result.Handicap))
    	log.info(&apos;Unknown_Hdp====&apos; + result.Handicap)
    }

     String selection_wsid = selection + &quot;_wsid&quot;
     String selection_mlid = selection + &quot;_mlid&quot;
     String selection_hdp = selection + &quot;_hdp&quot;
     String selection_o= selection + &quot;_o&quot;
          
     vars.put(selection_wsid,String.valueOf(result.WagerSelectionId))
    	vars.put(selection_mlid,String.valueOf(result.MarketlineId))
    	vars.put(selection_hdp,String.valueOf(result.Handicap))
    	vars.put(selection_o,String.valueOf(result.Odds))

}

</stringProp>
          </JSR223PostProcessor>
