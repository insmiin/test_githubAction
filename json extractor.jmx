          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">log.info(&apos;========pre processor =================&apos;)
int old_month = vars.get(&apos;month&apos;).toInteger()   //get existing var
log.info(&apos;old_month: &apos; + old_month)            

int new_month = old_month + 1                  //compute new_var using var
log.info(&apos;new_month: &apos; + new_month) 

vars.put(&quot;new_month&quot;,new_month.toString())     //save new_var
vars.put(&quot;month&quot;,new_month.toString())         //replace existing var with new_var

log.info(&apos;new_month: &apos; + vars.get(&apos;new_month&apos;))
log.info(&apos;existing month: &apos; + vars.get(&apos;month&apos;))</stringProp>
          </JSR223PreProcessor>
