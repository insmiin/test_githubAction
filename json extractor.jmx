            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 Assertion to check placebet status" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">
import groovy.json.JsonSlurper

def jsonSlurper = new JsonSlurper()
def wagsel_info = vars.get(&quot;WagerSelectionInfoPlaceBet_1&quot;)
placeBet_result = jsonSlurper.parseText(wagsel_info)
log.info(&apos;result postprocessor====&apos; + placeBet_result) 
log.info(&apos;placebet info betstatusmessage====&apos; + placeBet_result.BetStatusMessage)

if (placeBet_result.BetStatusMessage != &quot;100&quot;) {       //*check in response, BetStatusMessage is returning string &quot;100&quot;
	AssertionResult.setFailureMessage(&quot;Place Bet status message is not 100&quot;);
	AssertionResult.setFailure(true); 	
}

</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Assertion>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor (to get getbetinfo)" enabled="false">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">
import groovy.json.JsonSlurper

def jsonSlurper = new JsonSlurper()
def wagsel_info = vars.get(&quot;WagerSelectionInfo_1&quot;)
result = jsonSlurper.parseText(wagsel_info)
log.info(&apos;result postprocessor====&apos; + result) 
vars.put(&quot;getbetinfo_Status&quot;,String.valueOf(result.Status))  //use &quot;&quot; if it is jmeter variable
log.info(&apos;status value is=====&apos; + vars.get(&quot;getbetinfo_Status&quot;))

if (result.Status == 381 || result.Status == 100) {
	vars.put(&quot;getbetinfo_Handicap&quot;,String.valueOf(result.Handicap))
	vars.put(&quot;getbetinfo_Odds&quot;,String.valueOf(result.Odds))
}

log.info(&apos;testing value=====&apos; + vars.get(&quot;getbetinfo_Handicap&quot;))

</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 Assertion to check getbetinfo status" enabled="false">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper


	if (	vars.get(&quot;getbetinfo_Status&quot;) != &quot;381&quot; &amp; vars.get(&quot;getbetinfo_Status&quot;) != &quot;100&quot; ){
		AssertionResult.setFailureMessage(&quot;The api response status is not 381 or 100&quot;);
	    	AssertionResult.setFailure(true); 
	}

</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Assertion>
