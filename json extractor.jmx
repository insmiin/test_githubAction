            <stringProp name="script">/*
String jmeter_param = &quot;book_property_&quot; + &quot;1&quot;
log.info(&apos;jmeter_param: =======&apos; + jmeter_param)
def book_dict = vars.get(jmeter_param)    // to get variable value // !!!!! enclosed with &quot; &quot; if it is jmeter variable. no need &quot; &quot; if it is variable defined here !!!
log.info(&apos;book_dict: =======&apos; + book_dict)   
log.info(&apos;book_dict type :======&apos; + book_dict.getClass() )  //to get type of variable
*/
/*

/*

def body = prev.getResponseDataAsString();  //learn how to process json response 
log.info(&apos;body====&apos; + body.getClass())
*/
import groovy.json.JsonSlurper
 
int MatchNbr = vars.get(&quot;book_property_matchNr&quot;).toInteger()
log.info(&quot;MatchNbr====&quot;+MatchNbr)
for ( i in 1..MatchNbr ) {
    log.info(&quot;MatchNbr====&quot;+i);
    String jmeter_param = &quot;book_property_&quot; + i;
    log.info(&apos;jmeter_param: =======&apos; + jmeter_param)
  
    def jsonSlurper = new JsonSlurper()
    def book_list = vars.get(jmeter_param)
    cfg = jsonSlurper.parseText(book_list)
    log.info(&apos;cfg====&apos; + cfg)     // [name:Foo Bar, year:2018, timestamp:2018-03-08T00:00:00, tags:[person, employee], grade:3.14]
    log.info(&apos;cfg[name]====&apos;+cfg[&apos;category&apos;])  // Foo Bar
    log.info(&apos;cfg.name====&apos; + cfg.category)     // Foo Bar
}
</stringProp>
